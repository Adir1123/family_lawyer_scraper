# Family Lawyer Scraper — Environment Variables
# Copy this file to .env and fill in your values

# Apify — Facebook group scraping
# Get your token at: https://console.apify.com/account/integrations
APIFY_TOKEN=

# Anthropic — AI lead filtering (Claude)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Supabase — Database
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Trigger.dev — Task scheduling
# Get your key from: https://cloud.trigger.dev
TRIGGER_SECRET_KEY=

# Scraper settings (optional — defaults shown)
SCRAPER_MAX_POSTS=50
SCRAPER_LOOKBACK_HOURS=24

# AI confidence thresholds (optional — defaults shown)
# Posts scoring >= HIGH are auto-approved leads
# Posts scoring >= LOW but < HIGH are flagged for review
# Posts scoring < LOW go to trash
AI_CONFIDENCE_HIGH=0.85
AI_CONFIDENCE_LOW=0.60
