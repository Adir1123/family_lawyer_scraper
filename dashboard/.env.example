# Family Lawyer Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase — use the ANON key (NOT service_role!)
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Trigger.dev — for schedule management & manual runs (server-side only)
# Get from: https://cloud.trigger.dev → Project Settings → API Keys
TRIGGER_SECRET_KEY=
